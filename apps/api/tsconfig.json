{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@leadflow/config/typescript/node",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@modules/*": ["./src/modules/*"],
      "@middleware/*": ["./src/middleware/*"],
      "@shared/*": ["./src/shared/*"],
      "@plugins/*": ["./src/plugins/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
