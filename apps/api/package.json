    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.3.2",
    "prom-client": "^15.1.3",
    "stripe": "^22.3.0",
    "svix": "^1.96.1",
    "winston": "^3.13.0",
    "zod": "^3.25.76"
