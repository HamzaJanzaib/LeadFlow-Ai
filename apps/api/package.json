  "devDependencies": {
    "@leadflow/config": "workspace:*",
    "@prisma/client": "^5.16.0",
    "@types/node": "^20.14.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
