{
  "name": "@leadflow/api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --require ./src/monitoring/tracing.ts src/index.ts",
    "build": "tsc",
    "start": "node --require ./dist/monitoring/tracing.js dist/index.js",
