{
  "name": "leadflow-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @leadflow/db db:generate",
    "db:migrate": "pnpm --filter @leadflow/db db:migrate",
    "db:seed": "pnpm --filter @leadflow/db db:seed",
    "db:reset": "pnpm --filter @leadflow/db db:reset",
    "db:studio": "pnpm --filter @leadflow/db db:studio",
    "db:push": "pnpm --filter @leadflow/db db:push",
    "ai:eval": "pnpm --filter @leadflow/ai eval",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.4.0"
}
