# ══════════════════════════════════════════════════════════════════════════════
# LeadFlow AI — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://leadflow:leadflow@localhost:5434/leadflow_dev

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380
REDIS_PASSWORD=

# ─── Object Storage (MinIO) ───────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9002
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=leadflow-storage

# ─── Search (Meilisearch) ─────────────────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=masterKey

# ─── Authentication (Clerk) ───────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME

# ─── JWT (fallback if not using Clerk) ────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── AI Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-REPLACE_ME
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
GOOGLE_AI_API_KEY=REPLACE_ME

# ─── AI Observability (Langfuse) ──────────────────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-REPLACE_ME
LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_ME
LANGFUSE_BASE_URL=http://localhost:3101

# ─── Payments (Stripe) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ─── Email Delivery (Resend) ──────────────────────────────────────────────────
RESEND_API_KEY=re_REPLACE_ME
EMAIL_FROM=noreply@leadflow.ai
EMAIL_FROM_NAME=LeadFlow AI

# ─── Lead Data Providers ──────────────────────────────────────────────────────
APOLLO_API_KEY=REPLACE_ME
SERPAPI_KEY=REPLACE_ME
HUNTER_API_KEY=REPLACE_ME
NEVERBOUNCE_API_KEY=REPLACE_ME
GOOGLE_MAPS_API_KEY=REPLACE_ME

# ─── Reranking (Cohere) ───────────────────────────────────────────────────────
COHERE_API_KEY=REPLACE_ME

# ─── SMS (Twilio) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=REPLACE_ME
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_PHONE_NUMBER=REPLACE_ME

# ─── Notifications ────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-REPLACE_ME
SLACK_SIGNING_SECRET=REPLACE_ME
DISCORD_WEBHOOK_URL=REPLACE_ME

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── AI Budgets ───────────────────────────────────────────────────────────────
MAX_TOKENS_PER_REQUEST=8000
MAX_COST_PER_REQUEST_USD=0.10
TOOL_TIMEOUT_MS=30000
